# Telegram
TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# Local LLM server, OpenAI-compatible
# Recommended for low-resource laptops: Ollama + Qwen2.5 1.5B
# ollama pull qwen2.5:1.5b
# ollama serve
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:1.5b
LLM_API_KEY=EMPTY
LLM_TIMEOUT_SECONDS=90
LLM_MAX_TOKENS_CAP=900
ALLOW_LLM_FALLBACK=true

# SMTP email sending. For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=replace_with_app_password
SMTP_FROM=your_email@gmail.com

# Runtime folders
UPLOAD_DIR=data/uploads
LOG_DIR=data/logs
