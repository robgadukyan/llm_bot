# Telegram
TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# Local LLM server, OpenAI-compatible
# vLLM example:  vllm serve Qwen/Qwen2.5-7B-Instruct --served-model-name local-qwen --host 127.0.0.1 --port 8000
# llama.cpp example: ./llama-server -m ./models/model.gguf -c 4096 --host 127.0.0.1 --port 8000
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=local-qwen
LLM_API_KEY=EMPTY
LLM_TIMEOUT_SECONDS=120
ALLOW_LLM_FALLBACK=false

# SMTP email sending. For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=replace_with_app_password
SMTP_FROM=your_email@gmail.com

# Runtime folders
UPLOAD_DIR=data/uploads
LOG_DIR=data/logs
